generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id Int @id @default(autoincrement())
  name String
  profileKey String?
  password String 
  email String @unique
  isEmailConfirmed Boolean @default(false)
  registeredAt DateTime @default(now())
  loggedInAt DateTime?
  isPremium Boolean @default(false) 
  asset Assets[]
  homes Home[]
  userSetting UserSetting?
}

model PasswordReset{
  id Int @id @default(autoincrement())
  passwordKey String @unique()
  email String
  revoked Boolean
  issuedAt DateTime @default(now())
  expiresAt DateTime 
}

model ConfirmEmail{
  id Int @id  @default(autoincrement())
  emailCode String @unique()
  userId Int
  revoked Boolean
  issuedAt DateTime @default(now())
  expiresAt DateTime

}

model Home{
  id Int @id @default(autoincrement())
  yearBuilt Int?
  userId Int
  user User @relation(fields: [userId],references: [id])
  propertyType PropertyType
  profileKey String?
  address String?
  createdAt DateTime @default(now())
  rooms Room[]
  homeAsset HomeAssets[]

}

enum PropertyType{
  BUNGALOW
  DUPLEX
  MANSION
  APARTMENT
}

model Room{
  id Int @id @default(autoincrement())
  name String
  roomSize Int?
  floorLevel Int?
  homeId Int
  home Home @relation(fields: [homeId],references: [id])
  createdAt DateTime @default(now())
  roomAssets RoomAssets[]


}

model Assets{
  id Int @id @default(autoincrement())
  name String
  brandName String?
  modelName String?
  purchaseDate DateTime?
  notes String?
  roomAssets RoomAssets?
  homeAssets HomeAssets?
  userId Int
  user User @relation(fields: [userId],references: [id])
  createdAt DateTime @default(now())
  warranties Warranties[]
}

model RoomAssets{
  id Int @id 
  assets Assets @relation(fields: [id],references: [id])
  roomId Int
  room Room @relation(fields: [roomId],references: [id])  
  createdAt DateTime @default(now())
}

model HomeAssets{
  id Int @id
  assets Assets @relation(fields: [id], references: [id])
  homeId Int
  home Home @relation(fields: [homeId],references: [id])
  createdAt DateTime @default(now())
  
}


model UserSetting{
  id Int @id @default(autoincrement())
  enableEmailNotifications Boolean @default(false)
   userId Int @unique
  user User @relation(fields: [userId],references: [id])

}

model Warranties{
  id Int @id @default(autoincrement())
  providerName String
  startDate DateTime?
  expiryDate DateTime
  coverageNotes String?
   assetId Int
  asset Assets @relation(fields: [assetId],references: [id])
  createdAt DateTime @default(now())
  warrantyDocuments WarrantyDocuments[]
  warrantyStatus WarrantyStatus

}

model WarrantyDocuments{
  id Int @id @default(autoincrement())
  name String
  fileSize Int
  mimeType String
  warrantyId Int
  fileKey String?
  warranties Warranties @relation(fields: [warrantyId],references: [id])
  createdAt DateTime @default(now())
  
}

enum WarrantyStatus{
  ACTIVE
  EXPIRING_SOON
  EXPIRED
}

