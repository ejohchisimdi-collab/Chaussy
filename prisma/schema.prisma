generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User{
  id Int @id @default(autoincrement())
  name String
  profileKey String?
  password String 
  email String @unique
  isEmailConfirmed Boolean @default(false)
  registeredAt DateTime @default(now())
  loggedInAt DateTime?
  isPremium Boolean @default(false) 
  homes Home[]
}

model PasswordReset{
  id Int @id @default(autoincrement())
  passwordKey String @unique()
  email String
  revoked Boolean
  issuedAt DateTime @default(now())
  expiresAt DateTime 
}

model ConfirmEmail{
  id Int @id  @default(autoincrement())
  emailCode String @unique()
  userId Int
  revoked Boolean
  issuedAt DateTime @default(now())
  expiresAt DateTime

}

model Home{
  id Int @id @default(autoincrement())
  yearBuilt Int?
  userId Int
  user User @relation(fields: [userId],references: [id])
  propertyType PropertyType
  profileKey String?
  address String?
  createdAt DateTime @default(now())
  rooms Room[]

}

enum PropertyType{
  BUNGALOW
  DUPLEX
  MANSION
  APARTMENT
}

model Room{
  id Int @id @default(autoincrement())
  name String
  roomSize Int?
  floorLevel Int?
  homeId Int
  home Home @relation(fields: [homeId],references: [id])
  createdAt DateTime @default(now())


}